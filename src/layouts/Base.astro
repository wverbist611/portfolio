---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'William Verbist — Product & Experience Design Leader',
  description = 'Product and experience design leader creating new products to protect and save lives.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body>

  <header class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">William Verbist</a>
      <nav class="nav-links">
        <a href="/#work" class="nav-link">Work</a>
        <a href="/about" class="nav-link">About</a>
        <a href="mailto:hello@getvist.com" class="nav-link nav-contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-name">William Verbist</span>
      <a href="mailto:hello@getvist.com" class="footer-email text-link">hello@getvist.com</a>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.animate').forEach(el => observer.observe(el));
  </script>

</body>
</html>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  .nav-logo {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-link {
    font-size: 0.85rem;
    color: var(--muted);
    transition: color var(--transition);
  }

  .nav-link:hover { color: var(--text); }

  .nav-contact {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: text-decoration-color var(--transition);
  }

  .nav-contact:hover { text-decoration-color: var(--text); }

  .footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-name {
    font-family: var(--serif);
    font-size: 0.9rem;
    color: var(--muted);
  }

  .footer-email {
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media (max-width: 600px) {
    .nav-links { gap: 1.5rem; }
  }
</style>
